# WTI Crude Futures Options — instrument spec
# Iron rule: this is the ONLY place "T", "WTI", "EIA" appear.
family: futures_options
provider: settlement           # pipe-delimited EOD loader

symbol:
  product_id: 425               # stable key — join uses this, not name
  contract_root: T
  hub: WTI

data_file: "path/to/your/WTI.csv"  # set this to your local settlement CSV

columns:
  vol_col: ovx                  # CBOE OVX = WTI volatility index
  price_col: front_month_cont

price_field: settlement         # NOT last-trade
iv_source: provided             # use OPTION_VOLATILITY from exchange (validate first)
iv_raw_unit: percent            # raw OPTION_VOLATILITY is percent points (issue 002)
date_grain: eod

# Settlement availability + calendar policy (issues 022, 013): anchor availability
# to the ICE settlement release, never midnight of as_of_date. Source feed is ICE
# WTI Crude Futures (product_id 425, contract root T) per
# docs/reference/product_identity/wti/ — NOT NYMEX/CME.
exchange_tz: Europe/London
settlement_release_time: "19:30"  # ICE WTI futures settlement window close (London)
exchange_calendar: ICE
settlement_timing:
  time_kind: settlement_period_end
  local_time: "19:30:00"
  timezone: Europe/London
  same_day_file_availability_assumption: not_assumed
  source_reference: https://www.ice.com/products/213/WTI-Crude-Futures
  evidence_note: >
    Designated settlement period is 19:28:00-19:30:00 London time
    (14:28:00-14:30:00 EST) per ICE's official Designated Settlement Periods
    and Volume Thresholds documentation. See
    docs/reference/product_identity/wti/ for the product-identity evidence
    trail (ICE ticker T, not NYMEX/CME).

# Downstream option-chain Greeks export policy (issues 023/024).
export:
  product: WTI
  underlying_root: T
  option_root: T
  exchange: ICE
  currency: USD
  price_unit: USD_per_barrel
  contract_unit: 1000_barrels
  price_tick: 0.01
  equivalent_option_root_cme: LO  # only for consumers that explicitly want CME-style symbols

data_version: sha256:<fill-with-file-sha256>
data_file_sha256: <fill-with-file-sha256>
metrics_mode: strategy_required   # require explicit strategy/P&L returns for Stage 4 performance

pricing:
  model: black76                # futures options → Black-76
  iv_validate_threshold: 0.005
  validate_provided_iv: false   # trust exchange settlement IV; opt in only for a model self-test (issue 025)
  iv_validate_sample_size: 5000
  compute_greeks: false          # enable after universe narrowing if needed
  check_pcp: false               # run as sampled/offline quality check for large chains
  iv_solver_bounds: [0.0001, 5.0]
  vega_bucket_cutoff: 60
  vega_beta: 0.7

option_universe:
  min_dte_days: 1
  max_dte_days: 730
  min_option_price: 0.00001

dte:
  basis: calendar
  day_count: act_365
  expiry_cutoff: settlement
  exclude_expiry_date: true

event_calendars: [configs/events/eia.csv]
event_regimes: [eia_week]

available_at_lag:
  settlement: "0h"               # availability now anchored to settlement_release_time (issue 022)
  eia_inventory: "P5D"
  realized_vol: "2h"

validation:
  min_oi: 100
  iv_cap: 5.0
  futures_oi_floor: 1000
  roll_days: 5

stability:
  psi_threshold: 0.25
  use_iv_change: true

cv:
  n_folds: 8
  purge_bars: max_dte
  event_embargo_bars: 2
  regime_axes: [vol_regime, term_structure, vrp_sign, skew_direction, eia_week]
  max_concentration: 0.80
  kl_threshold: 0.5
  js_threshold: 0.3

performance:
  rf_rate_source: sofr
  net_greek_pnl: true
  include_roll_cost: true
  n_trials: 40
  stress_events: [eia_miss, roll_squeeze, vix_spike]

txcost:
  level: 2
  commission_per_contract: 2.50
  half_spread_fixed: 0.05
  dte_spread_curve:
    ">60": 1.0
    "30-60": 1.4
    "14-30": 1.8
    "<14": 2.8
  moneyness_otm_threshold: 0.15
  spread_regime_mult:
    low_vol: 0.85
    mid_vol: 1.00
    high_vol: 1.60
  financing_rate: 0.05
  margin_requirement: 0.10

audit:
  enabled: true
  snapshot_cols: [as_of_date, product_id, strike, expiry, price, iv_provided]
  hash_algo: xxh64
  retain_days: 30
