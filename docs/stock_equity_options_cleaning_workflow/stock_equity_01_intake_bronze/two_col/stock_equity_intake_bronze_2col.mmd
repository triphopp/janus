flowchart TB
    classDef box fill:#ffffff,stroke:#111111,stroke-width:1px,color:#111111;
    classDef gate fill:#f7f7f7,stroke:#111111,stroke-width:1px,color:#111111;
    classDef risk fill:#ffffff,stroke:#aa0000,stroke-width:1.2px,color:#111111;

    A["YAML config<br/>equity or equity_options"]:::box
    B["Fixed input guard<br/>sha256 or data_version"]:::gate
    C["Raw source frame<br/>stock bars or option chain"]:::box
    D["Bronze contract<br/>schema, semantic, PIT"]:::box
    E{"row pass?"}:::gate
    Q["quarantine<br/>reason counts"]:::risk
    F["Coverage SLA"]:::gate
    G["Family schema guard"]:::gate
    H["Bronze-ready frame"]:::box

    A --> B --> C --> D --> E
    E -->|no| Q
    E -->|yes| F --> G --> H
